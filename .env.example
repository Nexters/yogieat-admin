# CRA public env (build-time injected)
# Development
REACT_APP_API_URL=https://dev-api.yogieat.com
REACT_APP_ADMIN_API_PREFIX=/api/v1/admin
# Use mock API for wireframe flows.
# true: local mock service, false: real backend API
REACT_APP_USE_MOCK_API=true

